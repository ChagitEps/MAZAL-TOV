# מזל טוב AI — משתני סביבה (העתק ל-.env.local ומלא ערכים אמיתיים).
# .env* חסום ב-.gitignore — לעולם אין להעלות ערכים אמיתיים ל-git.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role: שרת בלבד (webhooks, אדמין, יצירת PDF). לעולם לא בצד לקוח.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI provider (ספק יחיד מאחורי lib/ai/provider.ts — אפיון §7.1) ---
AI_PROVIDER=anthropic            # anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Grow (תשלומים — אפיון §13) ---
GROW_API_KEY=
GROW_WEBHOOK_SECRET=

# --- כללי ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
