      { "key": "invitation", "label": "נוסח ההזמנה", "type": "textarea", "role": "body",
        "default": "בשבח והודיה להשי\"ת\nאנו מתכבדים להזמינכם\nלשמחת בר המצווה\nשל בננו היקר",
        "maxLength": 300, "aiEnabled": true },

      { "key": "boy", "label": "שם חתן הבר מצווה", "type": "text", "role": "name",
        "required": true, "placeholder": "לדוגמה: מלאכי נ\"י", "maxLength": 40, "aiEnabled": false },

      { "key": "date", "label": "תאריך", "type": "date", "role": "detail",
        "prefix": "שתתקיים אי\"ה ב", "required": true, "aiEnabled": false },

      { "key": "time", "label": "שעה", "type": "text", "role": "detail",
        "prefix": "בשעה ", "placeholder": "19:00", "maxLength": 20, "aiEnabled": false },

      { "key": "venue", "label": "מקום האירוע", "type": "text", "role": "detail",
        "prefix": "ב", "required": true, "placeholder": "אולמי \"ברזי'ק\"", "maxLength": 80, "aiEnabled": false },

      { "key": "address", "label": "כתובת", "type": "text", "role": "detail",
        "placeholder": "טבור הארץ 2, טבריה", "maxLength": 80, "aiEnabled": false },

      { "key": "closing", "label": "שורת סיום", "type": "text", "role": "signature",
        "default": "נשמח לראותכם משתתפים בשמחתנו", "maxLength": 80, "aiEnabled": true },

      { "key": "parents", "label": "שמות ההורים", "type": "text", "role": "signature",
        "emphasis": true, "required": true, "placeholder": "ברק ולינור אלמשעלי", "maxLength": 80, "aiEnabled": false },

      { "key": "grandparents_invite", "label": "שורת הזמנת הסבים", "type": "text", "role": "signature",
        "dependsOn": "grandparents",
        "default": "גם אנו מתכבדים להזמינכם להשתתף בשמחת נכדנו היקר",
        "maxLength": 120, "aiEnabled": true },

      { "key": "grandparents", "label": "שמות הסבים והסבתות", "type": "text", "role": "signature",
        "emphasis": true, "placeholder": "הרב דנין שליט\"א · הג' אילנה קהלני", "maxLength": 120, "aiEnabled": false }
    ]
  }
