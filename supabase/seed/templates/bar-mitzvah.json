      { "key": "navy",   "label": "כחול עמוק",  "bg": "#f3f6fa", "fg": "#182a45", "accent": "#1f4e79" },
      { "key": "olive",  "label": "עלי זית",     "bg": "#f6f8f3", "fg": "#28321f", "accent": "#5f7043" },
      { "key": "silver", "label": "כסוף חגיגי",  "bg": "#f7f7f9", "fg": "#2c2c34", "accent": "#6e7686" }
    ],
    "fields": [
      { "key": "blessing", "label": "פתיחה", "type": "text", "role": "opening",
